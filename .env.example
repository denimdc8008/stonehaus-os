# =============================================================
# STONEHAUS OS — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# =============================================================

# ─── DATABASE ────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/stonehaus_os"

# ─── NEXTAUTH ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-32-chars-min"
NEXTAUTH_URL="http://localhost:3000"

# ─── AWS (Production Deployment) ────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# S3 bucket for contract/document file storage
AWS_S3_BUCKET="stonehaus-os-documents"

# ─── EMAIL (Resend or SendGrid) ────────────────────────
# For password reset + critical date notifications
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@stonehaus.com"

# ─── MAPS / GIS ────────────────────────────────────
# For property map views (Mapbox recommended)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── POWER GRID / ERCOT APIS ───────────────────────
# Optional: ERCOT API access for power capacity data
ERCOT_API_KEY=""
ERCOT_API_URL="https://api.ercot.com/api/public-reports"

# ─── APPLICATION ────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Stonehaus OS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── FEATURE FLAGS ────────────────────────────────
NEXT_PUBLIC_ENABLE_MFA="false"
NEXT_PUBLIC_ENABLE_GIS_MAP="true"
NEXT_PUBLIC_ENABLE_POWER_GRID="false"
